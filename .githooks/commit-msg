#!/bin/bash
# Commit-msg hook for validating commit message format

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "Validating commit message format..."

# Check if commit message is empty
if [ -z "$COMMIT_MSG" ]; then
    echo -e "${RED}Commit message cannot be empty${NC}"
    exit 1
fi

# Skip validation for merge commits and revert commits
if echo "$COMMIT_MSG" | grep -qE "^(Merge|Revert)"; then
    echo -e "${GREEN}Merge/Revert commit - skipping validation${NC}"
    exit 0
fi

# Conventional Commits pattern
# Format: type(scope): subject
# Types: feat, fix, docs, style, refactor, test, chore, ci, perf, build

PATTERN="^(feat|fix|docs|style|refactor|test|chore|ci|perf|build)(\(.+\))?: .{1,50}"

if ! echo "$COMMIT_MSG" | head -n 1 | grep -qE "$PATTERN"; then
    echo -e "${RED}Invalid commit message format${NC}"
    echo ""
    echo "Commit messages must follow the Conventional Commits format:"
    echo "  type(scope): subject"
    echo ""
    echo "Allowed types:"
    echo "  feat     - A new feature"
    echo "  fix      - A bug fix"
    echo "  docs     - Documentation changes"
    echo "  style    - Code style changes (formatting, etc.)"
    echo "  refactor - Code refactoring"
    echo "  test     - Adding or updating tests"
    echo "  chore    - Maintenance tasks"
    echo "  ci       - CI/CD changes"
    echo "  perf     - Performance improvements"
    echo "  build    - Build system changes"
    echo ""
    echo "Examples:"
    echo "  feat(user-service): add JWT authentication"
    echo "  fix(mongodb): resolve connection timeout issue"
    echo "  docs: update deployment guide"
    echo "  chore(secrets): rotate production secrets"
    echo ""
    echo "Your commit message:"
    echo "  $COMMIT_MSG"
    exit 1
fi

# Check subject length (should be <= 50 characters for first line)
SUBJECT=$(echo "$COMMIT_MSG" | head -n 1 | sed -E 's/^[a-z]+(\(.+\))?: //')
if [ ${#SUBJECT} -gt 50 ]; then
    echo -e "${YELLOW}Warning: Subject line is longer than 50 characters (${#SUBJECT})${NC}"
    echo "Consider shortening the subject line."
fi

# Check that subject doesn't end with a period
if echo "$SUBJECT" | grep -q '\.$'; then
    echo -e "${YELLOW}Warning: Subject should not end with a period${NC}"
fi

# Check for imperative mood (basic check)
if echo "$SUBJECT" | grep -qiE "^(added|adding|fixed|fixing|updated|updating)"; then
    echo -e "${YELLOW}Warning: Use imperative mood in subject (e.g., 'add' instead of 'added')${NC}"
fi

# Check if body is present and has blank line after subject
if [ $(echo "$COMMIT_MSG" | wc -l) -gt 1 ]; then
    FIRST_LINE=$(echo "$COMMIT_MSG" | head -n 1)
    SECOND_LINE=$(echo "$COMMIT_MSG" | sed -n '2p')
    
    if [ -n "$SECOND_LINE" ]; then
        echo -e "${RED}Missing blank line between subject and body${NC}"
        echo "Add a blank line after the subject line."
        exit 1
    fi
fi

echo -e "${GREEN}Commit message validation passed!${NC}"
exit 0

#!/bin/bash
# Pre-commit hook for Helm project
# Validates YAML files and detects potential secrets

set -e

echo "Running pre-commit hooks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    echo "No staged files to check."
    exit 0
fi

# Check for YAML files
YAML_FILES=$(echo "$STAGED_FILES" | grep -E '\.ya?ml$' || true)

if [ -n "$YAML_FILES" ]; then
    echo -e "${YELLOW}Validating YAML files...${NC}"
    
    for file in $YAML_FILES; do
        if [ -f "$file" ]; then
            # Check if yamllint is available
            if command -v yamllint &> /dev/null; then
                if ! yamllint -d "{extends: default, rules: {line-length: {max: 120}, indentation: {spaces: 2}}}" "$file"; then
                    echo -e "${RED}YAML validation failed for $file${NC}"
                    exit 1
                fi
            else
                # Fallback to basic Python YAML validation
                if ! python3 -c "import yaml; yaml.safe_load(open('$file'))" 2>/dev/null; then
                    echo -e "${RED}YAML syntax error in $file${NC}"
                    exit 1
                fi
            fi
            echo -e "${GREEN}✓ $file${NC}"
        fi
    done
fi

# Secret detection
echo -e "${YELLOW}Checking for potential secrets...${NC}"

SECRET_PATTERNS=(
    "password\s*=\s*['\"][^'\"]+['\"]"
    "api[_-]?key\s*=\s*['\"][^'\"]+['\"]"
    "secret\s*=\s*['\"][^'\"]+['\"]"
    "token\s*=\s*['\"][^'\"]+['\"]"
    "AWS_ACCESS_KEY_ID"
    "AWS_SECRET_ACCESS_KEY"
    "private_key"
    "BEGIN.*PRIVATE KEY"
)

for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        # Skip secret files themselves
        if [[ "$file" == *"secret"* ]]; then
            continue
        fi
        
        for pattern in "${SECRET_PATTERNS[@]}"; do
            if grep -iE "$pattern" "$file" > /dev/null 2>&1; then
                echo -e "${RED}Potential secret detected in $file matching pattern: $pattern${NC}"
                echo "Please remove secrets before committing."
                exit 1
            fi
        done
    fi
done

echo -e "${GREEN}✓ No secrets detected${NC}"

# Check for hardcoded JWT secrets in non-secret files
echo -e "${YELLOW}Checking for hardcoded JWT secrets...${NC}"

for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        # Skip secret files and values files (they're supposed to have secrets)
        if [[ "$file" == *"secret"* ]] || [[ "$file" == *"values"* ]]; then
            continue
        fi
        
        if grep -i "JWT_SECRET" "$file" > /dev/null 2>&1; then
            echo -e "${RED}Hardcoded JWT_SECRET found in $file${NC}"
            echo "JWT secrets should be in Kubernetes secrets, not in templates."
            exit 1
        fi
    fi
done

echo -e "${GREEN}✓ No hardcoded JWT secrets found${NC}"

# Helm template validation if Chart.yaml or values files are changed
if echo "$STAGED_FILES" | grep -qE "(Chart\.yaml|values.*\.ya?ml)"; then
    echo -e "${YELLOW}Running Helm template validation...${NC}"
    
    if command -v helm &> /dev/null; then
        helm dependency update > /dev/null 2>&1 || true
        
        # Validate dev environment
        if helm template library-dev . -f values-dev.yaml --namespace library-dev > /dev/null 2>&1; then
            echo -e "${GREEN}✓ Helm template validation passed (dev)${NC}"
        else
            echo -e "${RED}Helm template validation failed (dev)${NC}"
            exit 1
        fi
        
        # Validate prod environment
        if helm template library-prod . -f values-prod.yaml --namespace library-prod > /dev/null 2>&1; then
            echo -e "${GREEN}✓ Helm template validation passed (prod)${NC}"
        else
            echo -e "${RED}Helm template validation failed (prod)${NC}"
            exit 1
        fi
    else
        echo -e "${YELLOW}Helm not found. Skipping Helm validation.${NC}"
    fi
fi

echo -e "${GREEN}Pre-commit hooks passed successfully!${NC}"
exit 0
